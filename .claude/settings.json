{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__vantage-peers__send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/coding/vantageos-team/.claude/hooks/enforce-no-task-in-message.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-pi-authorization-before-prod-deploy.py"
          },
          {
            "type": "command",
            "command": "python3 /root/coding/vantageos-team/.claude/hooks/auto-inject-signature.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 /root/coding/vantageos-team/.claude/hooks/enforce-eta-approval-before-npm-publish.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-ship-24-7.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__create_task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-ship-24-7.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__update_task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-ship-24-7.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__complete_task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-ship-24-7.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-friction-field.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__create_mission",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__update_mission",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__create_briefing_note",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__store_memory",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      },
      {
        "matcher": "mcp__vantage-peers__write_diary",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/block-time-estimates.py\""
          },
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-trust-system.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__vantage-peers__send_message",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/enforce-evidence-bound-notify.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"/root/coding/vantageos-team/.claude/hooks/monitor-npm-version-vs-deployed.py\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx convex deploy:*)",
      "Bash(npx convex run:*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(*)",
      "Agent(*)",
      "Glob(*)",
      "Grep(*)",
      "Write(.claude/skills/**/*.md)",
      "Write(.claude/skills/**/*.json)",
      "Edit(.claude/skills/**/*.md)",
      "Edit(.claude/skills/**/*.json)",
      "Write(.claude/agents/**/*.md)",
      "Edit(.claude/agents/**/*.md)",
      "Write(.claude/hooks/**/*.py)",
      "Edit(.claude/hooks/**/*.py)",
      "Write(.claude/commands/**/*.md)",
      "Edit(.claude/commands/**/*.md)"
    ],
    "deny": [
      "Write(**/.env*)",
      "Edit(**/.env*)",
      "Read(**/.env*)",
      "Write(**/.ssh/**)",
      "Edit(**/.ssh/**)",
      "Read(**/.ssh/**)",
      "Write(**/credentials/**)",
      "Edit(**/credentials/**)",
      "Read(**/credentials/**)",
      "Write(**/secrets/**)",
      "Edit(**/secrets/**)",
      "Read(**/secrets/**)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.json)"
    ]
  }
}
