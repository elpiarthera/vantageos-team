# vantageteam.dev — environment variables
# Copy to .env.local and fill in. Production values live in Vercel Dashboard
# → Project → Settings → Environment Variables (scope: Production).

# Public site URL — used by sitemap, canonical URLs, IndexNow helper.
NEXT_PUBLIC_SITE_URL=https://www.vantageteam.dev

# IndexNow — Bing/Yandex/Naver/Seznam/Yep real-time URL submission.
# This key is PUBLIC by design of the protocol (see /public/{key}.txt).
# See docs/INDEXNOW.md for the full pattern.
INDEXNOW_API_KEY=2ee69d41-b7ae-47b4-8c75-eeccdf6d3047

# Shared secret guarding POST /api/indexnow so only our own server actions /
# cron jobs / CI can trigger IndexNow submissions. NOT the IndexNow key.
# Generate locally with: openssl rand -hex 32
INTERNAL_API_SECRET=replace-me-with-openssl-rand-hex-32
